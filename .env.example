# ============================================
# EA-Video Environment Configuration
# All external ports use 58101-58200 range
# ============================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change_me_root_pw
MYSQL_USER=ea_video_user
MYSQL_PASSWORD=change_me_db_pw
MYSQL_PORT=58107

# --- Jitsi JWT Authentication ---
JWT_APP_ID=ea_video_telehealth
JWT_APP_SECRET=change_me_64char_hex_secret_here

# --- Jitsi Internal Passwords ---
JICOFO_AUTH_PASSWORD=change_me_jicofo
JVB_AUTH_PASSWORD=change_me_jvb

# --- Jitsi Public Access ---
JITSI_IMAGE_VERSION=stable
JITSI_PUBLIC_URL=https://meet.yourdomain.com:58103
JITSI_HTTPS_PORT=58103

# --- TURN/STUN (coturn uses host network, ports set in turnserver.conf) ---
TURN_HOST=turn.yourdomain.com
TURN_PORT=58105
TURNS_PORT=58106
TURN_CREDENTIALS=change_me_turn_secret
TURN_REALM=ea-video
JVB_ADVERTISE_IPS=YOUR_SERVER_PUBLIC_IP

# --- JVB Media ---
JVB_PORT=58104

# --- Backend ---
BACKEND_PORT=58102
API_SECRET=change_me_api_secret_for_admin_auth

# --- Frontend ---
FRONTEND_PORT=58101
VITE_API_URL=http://localhost:58102
VITE_JITSI_DOMAIN=meet.yourdomain.com:58103
